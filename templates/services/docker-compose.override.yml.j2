#########################################################################
#
# File: docker-compose.override.yml
# Tool: {{ allVars.dojo.tool }}
# Version: {{ allVars.dojo.version }}
# Created: {{ fileCreation }}
#
# Traefik owns the proxy network — other services declare it as external.
#
#########################################################################

services:
  app:
    networks:
      - {{ allVars.app.network | default('proxy') }}

networks:
  {{ allVars.app.network | default('proxy') }}:
    name: {{ allVars.app.network | default('proxy') }}
    external: true
